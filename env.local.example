# ClutchD Frontend — Environment Variables (Example)
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!
#
# ── Sections ─────────────────────────────────────────────────────────
# Required  — build/runtime will fail if missing
# Optional  — sensible defaults exist; override as needed
# Build-time — controls how the app is built

# ═══════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════

# Backend API URL (REST)
# Docker: http://localhost:8001/api
# Local:  http://localhost:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8001/api

# Backend WebSocket URL (real-time)
# Docker: ws://localhost:8001/ws
# Local:  ws://localhost:8000/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws

# ═══════════════════════════════════════════════════════════════════════
# OPTIONAL
# ═══════════════════════════════════════════════════════════════════════

# Google OAuth Client ID (required for SSO login)
# Leave as-is or set empty to disable Google sign-in.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Access token TTL in minutes (default: 15)
# Controls proactive token refresh interval (80% of TTL).
# NEXT_PUBLIC_ACCESS_TTL_MINUTES=15

# Demo mode (default: true)
# When true, the demo toolbar is available in the UI for exploring
# the app without a real backend. Set to "false" in production.
NEXT_PUBLIC_DEMO_MODE=true

# ═══════════════════════════════════════════════════════════════════════
# BUILD-TIME
# ═══════════════════════════════════════════════════════════════════════

# Build output mode (default: standalone)
#   standalone — optimized self-hosted Node server (default)
#   export     — static HTML export (no server required)
# NEXT_PUBLIC_BUILD_MODE=standalone
