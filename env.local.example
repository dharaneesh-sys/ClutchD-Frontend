# ClutchD Frontend — Environment Variables (Example)
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!

# Point to your local or production backend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Google OAuth (required for SSO)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Access token TTL (default: 15 min)
# NEXT_PUBLIC_ACCESS_TTL_MINUTES=15

# WebSocket port (default: 8000)
# NEXT_PUBLIC_WS_PORT=8000
