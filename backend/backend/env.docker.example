# ClutchD API — Environment Variables (Example)
#
# Copy this file to .env.docker and fill in your values.
# NEVER commit the actual .env.docker to git!

# ── Database ───────────────────────────────────────────
# PostgreSQL connection string (async)
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/clutchd
# Synchronous connection string (for Alembic / bootstrap)
SYNC_DATABASE_URL=postgresql://user:password@db:5432/clutchd

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Set a password for Redis (recommended for production):
# REDIS_PASSWORD=your-strong-redis-password

# ── Security ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── API Settings ───────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEV_AUTO_VERIFY_PROVIDERS=true
DEBUG=true

# ── Optional: Payment Gateways ─────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Optional: Google OAuth ─────────────────────────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ── Optional: Celery ───────────────────────────────────
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
